@using GestionInventaire.Web.Models.Maintenances
@model MaintenanceEditViewModel

@{
    ViewData["Title"] = "Modifier la maintenance";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/maintenance.css" asp-append-version="true" />
}

<div class="maintenance-form-page">

    <div class="mnt-header">
        <div class="mnt-header-left">
            <h1 class="mnt-heading">
                <i class="bi bi-pencil-square"></i>
                Modifier la maintenance
            </h1>
            <p class="mnt-heading-sub">@Model.CodeActif — @Model.NomProduit</p>
        </div>
        <a href="/Maintenances" class="btn-mnt-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour
        </a>
    </div>

    <div class="mnt-form-card">
        <div class="mnt-form-header">
            <div class="mnt-form-icon">
                <i class="bi bi-pencil"></i>
            </div>
            <div>
                <p class="mnt-form-card-title">Modifier l'intervention</p>
                <p class="mnt-form-card-subtitle">
                    Une maintenance terminée ne peut plus être modifiée
                </p>
            </div>
        </div>

        <div class="mnt-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="mnt-alert erreur"
                 style="margin-bottom:16px"></div>

            @* Actif en lecture seule *@
            <div class="mnt-actif-info" style="margin-bottom:20px">
                <i class="bi bi-box"></i>
                <span>
                    <strong>@Model.CodeActif</strong> — @Model.NomProduit
                </span>
            </div>

            <form method="post" id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IdMaintenance" />
                <input type="hidden" asp-for="CodeActif" />
                <input type="hidden" asp-for="NomProduit" />

                <div class="mnt-form-grid">

                    <div class="mnt-form-group">
                        <label class="mnt-form-label" asp-for="DateMaintenance">
                            <i class="bi bi-calendar"></i>
                            Date de maintenance
                        </label>
                        <input asp-for="DateMaintenance"
                               type="date"
                               class="mnt-input" />
                        <span asp-validation-for="DateMaintenance" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group">
                        <label class="mnt-form-label" asp-for="Cout">
                            <i class="bi bi-currency-dollar"></i>
                            Coût (HTG)
                        </label>
                        <input asp-for="Cout"
                               type="number"
                               step="0.01"
                               min="0"
                               class="mnt-input" />
                        <span asp-validation-for="Cout" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group">
                        <label class="mnt-form-label" asp-for="Statut">
                            <i class="bi bi-flag"></i>
                            Statut
                        </label>
                        <select asp-for="Statut"
                                asp-items="Model.Statuts"
                                class="mnt-select">
                        </select>
                        <span asp-validation-for="Statut" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group full-width">
                        <label class="mnt-form-label" asp-for="Description">
                            <i class="bi bi-text-left"></i>
                            Description
                        </label>
                        <textarea asp-for="Description"
                                  class="mnt-textarea"></textarea>
                        <span asp-validation-for="Description" class="mnt-field-error"></span>
                    </div>

                </div>
            </form>
        </div>

        <div class="mnt-form-footer">
            <button type="submit" form="editForm" class="btn-mnt-submit">
                <i class="bi bi-check-circle"></i>
                Enregistrer les modifications
            </button>
            <a href="/Maintenances" class="btn-mnt-cancel">
                <i class="bi bi-x"></i>
                Annuler
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
