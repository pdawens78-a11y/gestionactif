@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Réinitialiser mot de passe";
}

<div class="auth-card">
    <!-- En-tête avec logo -->
    <a href="/" class="auth-brand">
        <div class="auth-logo-box">
            <svg viewBox="0 0 24 24">
                <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" />
            </svg>
        </div>
        <span class="auth-brand-name">Technologis<span class="brand-dot">.</span></span>
    </a>

    <!-- Titre et sous-titre -->
    <h1 class="auth-title">Réinitialiser mot de passe</h1>
    <p class="auth-subtitle">Entrez votre email et votre nouveau mot de passe pour retrouver l'accès à votre compte.</p>

    <!-- Formulaire -->
    <form method="post">
        <!-- Validation summary -->
        <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

        <!-- Code caché -->
        <input asp-for="Input.Code" type="hidden" />

        <!-- Email -->
        <div class="auth-group">
            <label asp-for="Input.Email" class="auth-label">
                <i class="bi bi-envelope"></i> Email
            </label>
            <div class="auth-input-wrap">
                <input asp-for="Input.Email"
                       class="auth-input"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="votre.email@example.com" />
                <i class="bi bi-envelope"></i>
            </div>
            <span asp-validation-for="Input.Email" class="auth-error"></span>
        </div>

        <!-- Nouveau mot de passe -->
        <div class="auth-group">
            <label asp-for="Input.Password" class="auth-label">
                <i class="bi bi-lock"></i> Nouveau mot de passe
            </label>
            <div class="auth-input-wrap">
                <input asp-for="Input.Password"
                       class="auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Entrez un mot de passe sécurisé" />
                <i class="bi bi-lock"></i>
            </div>
            <span asp-validation-for="Input.Password" class="auth-error"></span>
        </div>

        <!-- Confirmer mot de passe -->
        <div class="auth-group">
            <label asp-for="Input.ConfirmPassword" class="auth-label">
                <i class="bi bi-lock-check"></i> Confirmer mot de passe
            </label>
            <div class="auth-input-wrap">
                <input asp-for="Input.ConfirmPassword"
                       class="auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Confirmez votre mot de passe" />
                <i class="bi bi-lock-check"></i>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="auth-error"></span>
        </div>

        <!-- Bouton submit -->
        <button type="submit" class="auth-btn">
            <i class="bi bi-check-circle"></i> Réinitialiser
        </button>

        <!-- Lien retour -->
        <div class="auth-footer-link">
            Vous vous souvenez de votre mot de passe ?
            <a asp-page="./Login">Se connecter</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}