@page
@model RegisterModel

@{
    ViewData["Title"] = "Créer un utilisateur";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/auth.css"
          asp-append-version="true" />
}

<div class="auth-card">

    <!-- BRAND -->
    <a class="auth-brand" href="/Dashboard">

        <div class="auth-logo-box">
            <svg viewBox="0 0 24 24">
                <path d="M3 7l9-4 9 4v10l-9 4-9-4V7z" />
                <path d="M12 3v18M3 7l9 4 9-4" />
            </svg>
        </div>

        <span class="auth-brand-name">
            Techno<span class="brand-dot">Logis</span>
        </span>

    </a>

    <!-- TITLE -->
    <h1 class="auth-title">
        Création d'utilisateur
    </h1>

    <p class="auth-subtitle">
        Créez un nouveau compte employé pour accéder à la plateforme.
    </p>

    <!-- VALIDATION -->
    <div asp-validation-summary="ModelOnly"
         class="auth-validation">
    </div>

    <!-- FORM -->
    <form id="registerForm"
          method="post">

        <!-- EMAIL -->
        <div class="auth-group">

            <label asp-for="Input.Email"
                   class="auth-label">
                Adresse e-mail
            </label>

            <div class="auth-input-wrap">

                <i class="bi bi-envelope"></i>

                <input asp-for="Input.Email"
                       class="auth-input"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="employe@technologis.com" />

            </div>

            <span asp-validation-for="Input.Email"
                  class="auth-error">
            </span>

        </div>

        <!-- PASSWORD -->
        <div class="auth-group">

            <label asp-for="Input.Password"
                   class="auth-label">
                Mot de passe temporaire
            </label>

            <div class="auth-input-wrap">

                <i class="bi bi-lock"></i>

                <input asp-for="Input.Password"
                       type="password"
                       class="auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="••••••••" />

            </div>

            <span asp-validation-for="Input.Password"
                  class="auth-error">
            </span>

        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="auth-group">

            <label asp-for="Input.ConfirmPassword"
                   class="auth-label">
                Confirmation du mot de passe
            </label>

            <div class="auth-input-wrap">

                <i class="bi bi-shield-lock"></i>

                <input asp-for="Input.ConfirmPassword"
                       type="password"
                       class="auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="••••••••" />

            </div>

            <span asp-validation-for="Input.ConfirmPassword"
                  class="auth-error">
            </span>

        </div>

        <!-- SUBMIT -->
        <button id="registerSubmit"
                type="submit"
                class="auth-btn">

            <i class="bi bi-person-plus"></i>

            Créer le compte

        </button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}