@using GestionInventaire.Web.Models.Employes
@model EmployeCreateViewModel

@{
    ViewData["Title"] = "Nouvel employé";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/employes.css" asp-append-version="true" />
}

<div class="employe-form-page">

    <div class="emp-header">
        <div class="emp-header-left">
            <h1 class="emp-heading">
                <i class="bi bi-person-plus"></i>
                Nouvel employé
            </h1>
            <p class="emp-heading-sub">Ajouter un membre au personnel</p>
        </div>
        <a href="/Employes" class="btn-emp-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour
        </a>
    </div>

    <div class="emp-form-card">
        <div class="emp-form-header">
            <div class="emp-form-icon">
                <i class="bi bi-person-vcard"></i>
            </div>
            <div>
                <p class="emp-form-card-title">Informations de l'employé</p>
                <p class="emp-form-card-subtitle">Nom et prénom obligatoires</p>
            </div>
        </div>

        <div class="emp-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="emp-alert erreur" style="margin-bottom:16px"></div>

            <form method="post" id="empForm">
                @Html.AntiForgeryToken()

                <div class="emp-form-grid">

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Prenom">
                            <i class="bi bi-person"></i> Prénom
                        </label>
                        <input asp-for="Prenom" class="emp-input"
                               placeholder="ex. Valdaya" />
                        <span asp-validation-for="Prenom" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Nom">
                            <i class="bi bi-person"></i> Nom
                        </label>
                        <input asp-for="Nom" class="emp-input"
                               placeholder="ex. Princivil" />
                        <span asp-validation-for="Nom" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Email">
                            <i class="bi bi-envelope"></i> E-mail
                            <span class="opt">(optionnel)</span>
                        </label>
                        <input asp-for="Email" class="emp-input"
                               placeholder="ex. v.princivil@technologis.com" />
                        <span asp-validation-for="Email" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Telephone">
                            <i class="bi bi-telephone"></i> Téléphone
                            <span class="opt">(optionnel)</span>
                        </label>
                        <input asp-for="Telephone" class="emp-input"
                               placeholder="ex. +509 3700 0000" />
                        <span asp-validation-for="Telephone" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group full-width">
                        <label class="emp-form-label" for="IdService">
                            <i class="bi bi-building"></i> Service / Département
                            <span class="opt">(optionnel)</span>
                        </label>
                        <div style="display:flex;gap:8px;">
                            <select asp-for="IdService" class="emp-input" style="flex:1;">
                                <option value="">-- Sélectionner un service --</option>
                                @foreach (var service in Model.Services)
                                {
                                    <option value="@service.IdService">@service.NomService</option>
                                }
                            </select>
                            <button type="button" id="btnAddService" class="btn-emp-submit"
                                    style="margin-top:0;white-space:nowrap;">
                                <i class="bi bi-plus"></i>
                                Nouveau
                            </button>
                        </div>
                        <span asp-validation-for="IdService" class="emp-field-error"></span>
                    </div>

                </div>
            </form>
        </div>

        <div class="emp-form-footer">
            <button type="submit" form="empForm" class="btn-emp-submit">
                <i class="bi bi-check-circle"></i>
                Créer l'employé
            </button>
            <a href="/Employes" class="btn-emp-cancel">
                <i class="bi bi-x"></i>
                Annuler
            </a>
        </div>
    </div>

</div>

<!-- Modal service -->
<div id="serviceModal" class="emp-modal">
    <div class="emp-modal-content">
        <div class="emp-modal-header">
            <h3 class="emp-modal-title">
                <i class="bi bi-building"></i> Nouveau Service
            </h3>
            <button type="button" class="emp-modal-close" id="closeServiceModal">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="emp-modal-body">
            <div class="emp-form-group">
                <label class="emp-form-label">Nom du service</label>
                <input type="text" id="newServiceName" class="emp-input"
                       placeholder="ex. Direction, Informatique, RH..." />
                <span id="serviceError" class="emp-field-error"></span>
            </div>
        </div>
        <div class="emp-modal-footer">
            <button type="button" class="btn-emp-submit" id="btnSaveService">
                <i class="bi bi-check-circle"></i> Créer
            </button>
            <button type="button" class="btn-emp-cancel" id="btnCancelService">
                <i class="bi bi-x"></i> Annuler
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnAdd     = document.getElementById('btnAddService');
            const modal      = document.getElementById('serviceModal');
            const btnClose   = document.getElementById('closeServiceModal');
            const btnSave    = document.getElementById('btnSaveService');
            const btnCancel  = document.getElementById('btnCancelService');
            const input      = document.getElementById('newServiceName');
            const errSpan    = document.getElementById('serviceError');
            const select     = document.querySelector('select[name="IdService"]');

            const open  = () => { modal.classList.add('open'); input.focus(); };
            const close = () => { modal.classList.remove('open'); input.value = ''; errSpan.textContent = ''; };

            btnAdd.addEventListener('click', e => { e.preventDefault(); open(); });
            btnClose.addEventListener('click', close);
            btnCancel.addEventListener('click', close);
            modal.addEventListener('click', e => { if (e.target === modal) close(); });

            btnSave.addEventListener('click', async function () {
                const nom = input.value.trim();
                if (!nom) { errSpan.textContent = 'Le nom du service est obligatoire.'; return; }

                btnSave.disabled = true;
                errSpan.textContent = '';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const res   = await fetch('/Employes/CreateServiceAjax', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ nomService: nom })
                    });

                    if (!res.ok) {
                        const err = await res.json();
                        errSpan.textContent = err.message || 'Erreur.';
                        return;
                    }

                    const data   = await res.json();
                    const option = document.createElement('option');
                    option.value     = data.idService;
                    option.textContent = data.nomService;
                    option.selected  = true;
                    select.appendChild(option);
                    close();
                } catch (e) {
                    errSpan.textContent = 'Une erreur inattendue est survenue.';
                } finally {
                    btnSave.disabled = false;
                }
            });

            input.addEventListener('keypress', e => { if (e.key === 'Enter') btnSave.click(); });
        });
    </script>
}
