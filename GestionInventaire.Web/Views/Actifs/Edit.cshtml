@using GestionInventaire.Web.Models.Produits
@model ProduitEditViewModel

@{
    ViewData["Title"] = "Modifier le produit";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/produits.css" asp-append-version="true" />
}

<div class="produit-form-page">

    <div class="prod-header">
        <div class="prod-header-left">
            <h1 class="prod-heading">
                <i class="bi bi-pencil-square"></i>
                Modifier le produit
            </h1>
            <p class="prod-heading-sub">@Model.NomProduit</p>
        </div>
        <a href="/Produits" class="btn-prod-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour
        </a>
    </div>

    <form method="post" id="editForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdProduit" />
        <input type="hidden" asp-for="NombreActifs" />

        @* ══ SECTION 1 — Informations produit ══ *@
        <div class="prod-form-card" style="margin-bottom:16px">
            <div class="prod-form-header">
                <div class="prod-form-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <p class="prod-form-card-title">Informations du produit</p>
                    <p class="prod-form-card-subtitle">Nom, catégorie et description</p>
                </div>
            </div>

            <div class="prod-form-body">
                <div asp-validation-summary="ModelOnly"
                     class="prod-alert erreur"
                     style="margin-bottom:16px"></div>

                <div class="prod-form-group">
                    <label class="prod-form-label" asp-for="NomProduit">
                        <i class="bi bi-box"></i> Nom du produit
                    </label>
                    <input asp-for="NomProduit" class="prod-input" />
                    <span asp-validation-for="NomProduit" class="prod-field-error"></span>
                </div>

                <div class="prod-form-group">
                    <label class="prod-form-label" asp-for="IdCategorie">
                        <i class="bi bi-tag"></i> Catégorie
                    </label>
                    <select asp-for="IdCategorie"
                            asp-items="Model.Categories"
                            class="prod-select">
                        <option value="">— Sélectionner une catégorie —</option>
                    </select>
                    <span asp-validation-for="IdCategorie" class="prod-field-error"></span>
                </div>

                <div class="prod-form-group">
                    <label class="prod-form-label" asp-for="Description">
                        <i class="bi bi-text-left"></i> Description
                        <span style="color:var(--muted);font-weight:400">(optionnel)</span>
                    </label>
                    <textarea asp-for="Description" class="prod-textarea"></textarea>
                    <span asp-validation-for="Description" class="prod-field-error"></span>
                </div>
            </div>
        </div>

        @* ══ SECTION 2 — Actifs (info) ══ *@
        <div class="prod-form-card" style="margin-bottom:16px">
            <div class="prod-form-header">
                <div class="prod-form-icon" style="background:linear-gradient(135deg,var(--accent),#00b894)">
                    <i class="bi bi-boxes"></i>
                </div>
                <div>
                    <p class="prod-form-card-title">Actifs associés</p>
                    <p class="prod-form-card-subtitle">
                        @Model.NombreActifs actif(s) actuellement enregistré(s) dans le système
                    </p>
                </div>
            </div>
        </div>

        @* ══ FOOTER ══ *@
        <div class="prod-form-footer"
             style="background:var(--surface);padding:16px 22px;border-radius:12px;
                    display:flex;align-items:center;gap:10px;flex-wrap:wrap">

            @* 1. Enregistrer *@
            <button type="submit"
                    class="btn-prod-submit"
                    style="cursor:pointer;border:none">
                <i class="bi bi-check-circle"></i>
                Enregistrer les modifications
            </button>

            @* 2. Annuler *@
            <a href="/Produits" class="btn-prod-cancel">
                <i class="bi bi-x"></i>
                Annuler
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
