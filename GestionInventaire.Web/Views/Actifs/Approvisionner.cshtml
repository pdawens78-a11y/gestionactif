@using GestionInventaire.Web.Models.Actifs
@model ApprovisionnerViewModel

@{
    ViewData["Title"] = "Approvisionner";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/actifs.css" asp-append-version="true" />
}

<div class="actif-form-page">

    <div class="actif-header">
        <div class="actif-header-left">
            <h1 class="actif-heading">
                <i class="bi bi-boxes"></i>
                Approvisionner
            </h1>
            <p class="actif-heading-sub">Générer des actifs en masse pour un produit</p>
        </div>
        <a href="/Produits" class="btn-actif-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour aux produits
        </a>
    </div>

    <form method="post" id="approForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdProduit" />
        <input type="hidden" asp-for="NomProduit" />
        <input type="hidden" asp-for="NomCategorie" />
        <input type="hidden" asp-for="StockActuel" />
        <input type="hidden" asp-for="NombreActifs" />
        <input type="hidden" asp-for="QuantiteAuto" />

        <div class="actif-form-card">
            <div class="actif-form-header">
                <div class="actif-form-icon">
                    <i class="bi bi-boxes"></i>
                </div>
                <div>
                    <p class="actif-form-card-title">Génération automatique d'actifs</p>
                    <p class="actif-form-card-subtitle">
                        Les codes inventaire seront générés automatiquement
                    </p>
                </div>
            </div>

            <div class="actif-form-body">

                @* Info produit *@
                <div style="background:var(--surface2);border:1px solid var(--border);
                            border-radius:10px;padding:14px 16px;margin-bottom:20px;
                            display:flex;align-items:center;gap:14px">
                    <div style="width:38px;height:38px;border-radius:9px;
                                background:linear-gradient(135deg,var(--accent2),#1d4ed8);
                                display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="bi bi-box-seam" style="color:#fff;font-size:17px"></i>
                    </div>
                    <div>
                        <div style="font-weight:600;color:var(--text);font-size:0.9rem">
                            @Model.NomProduit
                        </div>
                        <div style="font-size:0.75rem;color:var(--muted)">
                            <i class="bi bi-tag" style="font-size:11px"></i>
                            @Model.NomCategorie
                        </div>
                    </div>
                    @* Compteurs stock vs actifs *@
                    <div style="margin-left:auto;display:flex;gap:16px;text-align:center">
                        <div>
                            <div style="font-family:'Space Mono',monospace;font-size:1.1rem;
                                        font-weight:700;color:var(--warn)">
                                @Model.StockActuel
                            </div>
                            <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase">
                                Stock cible
                            </div>
                        </div>
                        <div style="color:var(--border);font-size:1.2rem;align-self:center">—</div>
                        <div>
                            <div style="font-family:'Space Mono',monospace;font-size:1.1rem;
                                        font-weight:700;color:var(--muted)">
                                @Model.NombreActifs
                            </div>
                            <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase">
                                Actifs créés
                            </div>
                        </div>
                        <div style="color:var(--border);font-size:1.2rem;align-self:center">=</div>
                        <div>
                            <div style="font-family:'Space Mono',monospace;font-size:1.1rem;
                                        font-weight:700;color:var(--accent)">
                                @Model.ActifsManquants
                            </div>
                            <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase">
                                À générer
                            </div>
                        </div>
                    </div>
                </div>

                @* Bandeau info si quantité auto *@
                @if (Model.QuantiteAuto)
                {
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;
                                    background:rgba(0,212,170,0.07);
                                    border:1px solid rgba(0,212,170,0.25);
                                    border-radius:8px;margin-bottom:20px;
                                    font-size:0.8rem;color:var(--accent)">
                        <i class="bi bi-magic" style="font-size:16px;flex-shrink:0"></i>
                        <span>
                            Quantité calculée automatiquement :
                            <strong>@Model.StockActuel stock</strong> −
                            <strong>@Model.NombreActifs actifs existants</strong> =
                            <strong>@Model.ActifsManquants actif(s) à créer</strong>
                        </span>
                    </div>
                }

                @* Nombre d'actifs *@
                <div class="actif-form-group">
                    <label class="actif-form-label" asp-for="Quantite">
                        <i class="bi bi-hash"></i>
                        Nombre d'actifs à générer
                    </label>
                    <input asp-for="Quantite"
                           type="number"
                           min="1"
                           max="10000"
                           class="actif-input"
                           id="quantiteInput"
                           style="max-width:200px" />
                    <span asp-validation-for="Quantite" class="actif-field-error"></span>
                    @if (!Model.QuantiteAuto)
                    {
                        <small style="font-size:0.72rem;color:var(--muted)">
                            Entrez une quantité pour voir l'aperçu des codes générés.
                        </small>
                    }
                </div>

                @* Aperçu codes *@
                <div id="approPreview"
                     style="display:none;padding:10px 14px;
                            background:rgba(0,212,170,0.06);
                            border:1px solid rgba(0,212,170,0.2);
                            border-radius:8px;font-size:0.8rem;
                            color:var(--accent);margin-bottom:16px">
                    <i class="bi bi-info-circle"></i>
                    <span id="previewText"></span>
                </div>

                @* Localisation *@
                <div class="actif-form-group">
                    <label class="actif-form-label" asp-for="Localisation">
                        <i class="bi bi-geo-alt"></i>
                        Localisation (commune à tous les actifs générés)
                    </label>
                    <input asp-for="Localisation"
                           class="actif-input"
                           placeholder="ex. Salle Serveur A, Entrepôt B..." />
                    <span asp-validation-for="Localisation" class="actif-field-error"></span>
                </div>

            </div>

            <div class="actif-form-footer">
                <button type="submit" class="btn-actif-submit" style="cursor:pointer;border:none">
                    <i class="bi bi-boxes"></i>
                    Générer les actifs
                </button>
                <a href="/Produits" class="btn-actif-cancel">
                    <i class="bi bi-x"></i>
                    Annuler
                </a>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const qInput   = document.getElementById('quantiteInput');
        const preview  = document.getElementById('approPreview');
        const prevText = document.getElementById('previewText');

        function updatePreview() {
            const qty = parseInt(qInput.value) || 0;
            if (qty > 0) {
                preview.style.display = 'block';
                prevText.textContent =
                    `${qty} actif(s) seront générés avec des codes inventaire séquentiels.`;
            } else {
                preview.style.display = 'none';
            }
        }

        qInput?.addEventListener('input', updatePreview);
        updatePreview();
    </script>
}
