@{
    ViewData["Title"] = "Paramètres";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/settings.css"
          asp-append-version="true" />
}

<div class="settings-page">

    <div class="settings-card">

        <!-- Icon -->
        <div class="settings-icon">
            <i class="bi bi-gear"></i>
        </div>

        <!-- Title -->
        <h1 class="settings-title">
            Paramètres
        </h1>

        <!-- Subtitle -->
        <p class="settings-subtitle">
            Cette fonctionnalité sera disponible
            dans une prochaine mise à jour.
        </p>

        <!-- Status -->
        <div class="settings-badge">

            <span class="pulse"></span>

            Développement en cours

        </div>

        <!-- Description -->
        <div class="settings-info">

            <p>
                Les paramètres avancés de l'application
                permettront bientôt de gérer :
            </p>

            <ul>
                <li>Préférences utilisateur</li>
                <li>Configuration système</li>
                <li>Sécurité avancée</li>
                <li>Notifications</li>
                <li>Sauvegardes et maintenance</li>
            </ul>

        </div>

        <!-- Back -->
        <a href="/Dashboard"
           class="settings-back-btn">

            <i class="bi bi-arrow-left"></i>
            Retour au Dashboard

        </a>

    </div>

</div>