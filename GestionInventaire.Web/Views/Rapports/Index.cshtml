@using GestionInventaire.Web.Models.Rapports
@model RapportIndexViewModel

@{
    ViewData["Title"] = "Rapports";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/rapport.css" asp-append-version="true" />
}

<div class="rapport-page">

    @* ── En-tête ── *@
    <div class="rapport-header">
        <div class="rapport-header-left">
            <h1 class="rapport-heading">
                <i class="bi bi-file-earmark-bar-graph"></i>
                Rapports opérationnels
            </h1>
            <p class="rapport-heading-sub">
                Généré le @Model.DateGenerationFormatted
            </p>
        </div>
        <div class="rapport-actions">
            <button onclick="window.print()" class="btn-rapport-print">
                <i class="bi bi-printer"></i>
                Imprimer
            </button>
        </div>
    </div>

    @if (TempData["Erreur"] != null)
    {
        <div style="padding:10px 14px;border-radius:8px;font-size:0.82rem;display:flex;align-items:center;gap:8px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);color:#fca5a5">
            <i class="bi bi-exclamation-circle"></i>
            @TempData["Erreur"]
        </div>
    }

    @* ── KPI résumé ── *@
    <div class="rapport-kpi-grid">
        <div class="rapport-kpi actifs">
            <div class="rapport-kpi-icon"><i class="bi bi-box-seam"></i></div>
            <div>
                <div class="rapport-kpi-val">@Model.Inventaire.TotalActifs</div>
                <div class="rapport-kpi-label">Actifs total</div>
            </div>
        </div>
        <div class="rapport-kpi stock">
            <div class="rapport-kpi-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <div>
                <div class="rapport-kpi-val">@Model.Stock.StocksCritiques</div>
                <div class="rapport-kpi-label">Stocks critiques</div>
            </div>
        </div>
        <div class="rapport-kpi affectations">
            <div class="rapport-kpi-icon"><i class="bi bi-person-check"></i></div>
            <div>
                <div class="rapport-kpi-val">@Model.Affectations.TotalActives</div>
                <div class="rapport-kpi-label">Affectations actives</div>
            </div>
        </div>
        <div class="rapport-kpi maintenances">
            <div class="rapport-kpi-icon"><i class="bi bi-wrench"></i></div>
            <div>
                <div class="rapport-kpi-val">@Model.Maintenances.CoutTotalFormatted</div>
                <div class="rapport-kpi-label">Coût maintenances</div>
            </div>
        </div>
    </div>

    @* ══════════════════════════════════════
       SECTION 1 — Inventaire des actifs
    ══════════════════════════════════════ *@
    <div class="rapport-section s1 open" id="s1">
        <div class="rapport-section-header" onclick="toggleSection('s1')">
            <div class="rapport-section-title">
                <div class="rapport-section-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                Inventaire des actifs
                <small style="color:var(--muted);font-weight:400;font-size:0.75rem">
                    @Model.Inventaire.TotalDisponibles dispo ·
                    @Model.Inventaire.TotalAffectes affectés ·
                    @Model.Inventaire.TotalEnMaintenance maintenance ·
                    @Model.Inventaire.TotalHorsService hors service
                </small>
            </div>
            <div class="rapport-section-meta">
                <a href="/Rapports/ExportCsv?section=inventaire"
                   class="btn-export-csv"
                   onclick="event.stopPropagation()">
                    <i class="bi bi-download"></i> CSV
                </a>
                <span class="rapport-section-count">@Model.Inventaire.TotalActifs</span>
                <i class="bi bi-chevron-up rapport-section-toggle"></i>
            </div>
        </div>
        <div class="rapport-section-body">
            @if (Model.Inventaire.Actifs.Any())
            {
                <table class="rapport-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Produit</th>
                            <th>Catégorie</th>
                            <th>Localisation</th>
                            <th>Statut</th>
                            <th>Acquisition</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Inventaire.Actifs)
                        {
                            <tr>
                                <td><span class="rapport-code">@row.CodeInventaire</span></td>
                                <td>@row.NomProduit</td>
                                <td><span style="font-size:0.72rem;color:var(--muted)">@row.NomCategorie</span></td>
                                <td><span style="font-size:0.72rem;color:var(--muted)">@row.Localisation</span></td>
                                <td><span class="@row.StatutClass">@row.StatutLabel</span></td>
                                <td><span style="font-family:'Space Mono',monospace;font-size:0.72rem;color:var(--muted)">@row.DateFormatted</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="rapport-empty">Aucun actif enregistré.</div>
            }
        </div>
    </div>

    @* ══════════════════════════════════════
       SECTION 2 — État du stock
    ══════════════════════════════════════ *@
    <div class="rapport-section s2" id="s2">
        <div class="rapport-section-header" onclick="toggleSection('s2')">
            <div class="rapport-section-title">
                <div class="rapport-section-icon">
                    <i class="bi bi-archive"></i>
                </div>
                État du stock
                <small style="color:var(--muted);font-weight:400;font-size:0.75rem">
                    @Model.Stock.StocksCritiques critique(s) ·
                    @Model.Stock.StocksEpuises épuisé(s)
                </small>
            </div>
            <div class="rapport-section-meta">
                <a href="/Rapports/ExportCsv?section=stock"
                   class="btn-export-csv"
                   onclick="event.stopPropagation()">
                    <i class="bi bi-download"></i> CSV
                </a>
                <span class="rapport-section-count">@Model.Stock.TotalProduits</span>
                <i class="bi bi-chevron-down rapport-section-toggle"></i>
            </div>
        </div>
        <div class="rapport-section-body">
            @if (Model.Stock.Stocks.Any())
            {
                <table class="rapport-table">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th>Catégorie</th>
                            <th>Quantité</th>
                            <th>Seuil alerte</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Stock.Stocks)
                        {
                            <tr>
                                <td>@row.NomProduit</td>
                                <td><span style="font-size:0.72rem;color:var(--muted)">@row.NomCategorie</span></td>
                                <td>
                                    <span style="font-family:'Space Mono',monospace;font-size:0.82rem;font-weight:700"
                                          class="@row.StatusClass">
                                        @row.Quantite
                                    </span>
                                </td>
                                <td><span style="font-family:'Space Mono',monospace;font-size:0.72rem;color:var(--muted)">≤ @row.SeuilAlerte</span></td>
                                <td><span class="@row.StatusClass">@row.StatusLabel</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="rapport-empty">Aucun stock enregistré.</div>
            }
        </div>
    </div>

    @* ══════════════════════════════════════
       SECTION 3 — Affectations actives
    ══════════════════════════════════════ *@
    <div class="rapport-section s3" id="s3">
        <div class="rapport-section-header" onclick="toggleSection('s3')">
            <div class="rapport-section-title">
                <div class="rapport-section-icon">
                    <i class="bi bi-person-check"></i>
                </div>
                Affectations actives
            </div>
            <div class="rapport-section-meta">
                <a href="/Rapports/ExportCsv?section=affectations"
                   class="btn-export-csv"
                   onclick="event.stopPropagation()">
                    <i class="bi bi-download"></i> CSV
                </a>
                <span class="rapport-section-count">@Model.Affectations.TotalActives</span>
                <i class="bi bi-chevron-down rapport-section-toggle"></i>
            </div>
        </div>
        <div class="rapport-section-body">
            @if (Model.Affectations.Affectations.Any())
            {
                <table class="rapport-table">
                    <thead>
                        <tr>
                            <th>Code actif</th>
                            <th>Produit</th>
                            <th>Employé</th>
                            <th>Service</th>
                            <th>Depuis le</th>
                            <th>Durée</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Affectations.Affectations)
                        {
                            <tr>
                                <td><span class="rapport-code">@row.CodeActif</span></td>
                                <td>@row.NomProduit</td>
                                <td>@row.NomEmploye</td>
                                <td><span style="font-size:0.72rem;color:var(--muted)">@row.Service</span></td>
                                <td><span style="font-family:'Space Mono',monospace;font-size:0.72rem;color:var(--muted)">@row.DateDebutFormatted</span></td>
                                <td>
                                    <span style="font-size:0.75rem;color:var(--accent);font-weight:600">
                                        @row.DureeLabel
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="rapport-empty">Aucune affectation active.</div>
            }
        </div>
    </div>

    @* ══════════════════════════════════════
       SECTION 4 — Maintenances & coûts
    ══════════════════════════════════════ *@
    <div class="rapport-section s4" id="s4">
        <div class="rapport-section-header" onclick="toggleSection('s4')">
            <div class="rapport-section-title">
                <div class="rapport-section-icon">
                    <i class="bi bi-wrench-adjustable"></i>
                </div>
                Maintenances & coûts
                <small style="color:var(--muted);font-weight:400;font-size:0.75rem">
                    Total : @Model.Maintenances.CoutTotalFormatted ·
                    @Model.Maintenances.EnCours en cours
                </small>
            </div>
            <div class="rapport-section-meta">
                <a href="/Rapports/ExportCsv?section=maintenances"
                   class="btn-export-csv"
                   onclick="event.stopPropagation()">
                    <i class="bi bi-download"></i> CSV
                </a>
                <span class="rapport-section-count">@Model.Maintenances.TotalMaintenances</span>
                <i class="bi bi-chevron-down rapport-section-toggle"></i>
            </div>
        </div>
        <div class="rapport-section-body">
            @if (Model.Maintenances.Maintenances.Any())
            {
                <table class="rapport-table">
                    <thead>
                        <tr>
                            <th>Code actif</th>
                            <th>Produit</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th>Coût</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Maintenances.Maintenances)
                        {
                            <tr>
                                <td><span class="rapport-code">@row.CodeActif</span></td>
                                <td>@row.NomProduit</td>
                                <td><span style="font-family:'Space Mono',monospace;font-size:0.72rem;color:var(--muted)">@row.DateFormatted</span></td>
                                <td><span class="@row.StatutClass">@row.StatutLabel</span></td>
                                <td><span style="font-family:'Space Mono',monospace;font-size:0.75rem;color:var(--warn)">@row.CoutFormatted</span></td>
                                <td>
                                    <span style="font-size:0.75rem;color:var(--muted);max-width:220px;display:inline-block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                        @row.Description
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="rapport-empty">Aucune maintenance enregistrée.</div>
            }
        </div>
    </div>

    @* ── Pied de page ── *@
    <div class="rapport-footer-bar">
        <span>
            <i class="bi bi-info-circle"></i>
            Rapport généré le @Model.DateGenerationFormatted — TechnoLogis S.A.
        </span>
        <span>
            @Model.Inventaire.TotalActifs actifs ·
            @Model.Stock.TotalProduits produits ·
            @Model.Affectations.TotalActives affectations ·
            @Model.Maintenances.TotalMaintenances maintenances
        </span>
    </div>

</div>

@section Scripts {
    <script>
        function toggleSection(id) {
            const section = document.getElementById(id);
            section.classList.toggle('open');
        }
    </script>
}
