@using GestionInventaire.Web.Models.Maintenances
@model MaintenanceCreateViewModel

@{
    ViewData["Title"] = "Planifier une maintenance";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/maintenance.css" asp-append-version="true" />
}

<div class="maintenance-form-page">

    <div class="mnt-header">
        <div class="mnt-header-left">
            <h1 class="mnt-heading">
                <i class="bi bi-calendar-plus"></i>
                Planifier une maintenance
            </h1>
            <p class="mnt-heading-sub">L'actif passera automatiquement en statut « En maintenance »</p>
        </div>
        <a href="/Maintenances" class="btn-mnt-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour
        </a>
    </div>

    <div class="mnt-form-card">
        <div class="mnt-form-header">
            <div class="mnt-form-icon">
                <i class="bi bi-wrench"></i>
            </div>
            <div>
                <p class="mnt-form-card-title">Informations de la maintenance</p>
                <p class="mnt-form-card-subtitle">Tous les champs sont obligatoires sauf le coût</p>
            </div>
        </div>

        <div class="mnt-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="mnt-alert erreur"
                 style="margin-bottom:16px"></div>

            <form method="post" id="mntForm">
                @Html.AntiForgeryToken()

                <div class="mnt-form-grid">

                    <div class="mnt-form-group full-width">
                        <label class="mnt-form-label" asp-for="IdActif">
                            <i class="bi bi-box"></i>
                            Actif concerné
                        </label>
                        <select asp-for="IdActif"
                                asp-items="Model.Actifs"
                                class="mnt-select">
                            <option value="">— Sélectionner un actif —</option>
                        </select>
                        <span asp-validation-for="IdActif" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group">
                        <label class="mnt-form-label" asp-for="DateMaintenance">
                            <i class="bi bi-calendar"></i>
                            Date de maintenance
                        </label>
                        <input asp-for="DateMaintenance"
                               type="date"
                               class="mnt-input" />
                        <span asp-validation-for="DateMaintenance" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group">
                        <label class="mnt-form-label" asp-for="Cout">
                            <i class="bi bi-currency-dollar"></i>
                            Coût estimé (HTG)
                        </label>
                        <input asp-for="Cout"
                               type="number"
                               step="0.01"
                               min="0"
                               class="mnt-input"
                               placeholder="0.00" />
                        <span asp-validation-for="Cout" class="mnt-field-error"></span>
                    </div>

                    <div class="mnt-form-group full-width">
                        <label class="mnt-form-label" asp-for="Description">
                            <i class="bi bi-text-left"></i>
                            Description de l'intervention
                        </label>
                        <textarea asp-for="Description"
                                  class="mnt-textarea"
                                  placeholder="Décrivez l'intervention à effectuer..."></textarea>
                        <span asp-validation-for="Description" class="mnt-field-error"></span>
                    </div>

                </div>
            </form>
        </div>

        <div class="mnt-form-footer">
            <button type="submit" form="mntForm" class="btn-mnt-submit">
                <i class="bi bi-check-circle"></i>
                Planifier la maintenance
            </button>
            <a href="/Maintenances" class="btn-mnt-cancel">
                <i class="bi bi-x"></i>
                Annuler
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
