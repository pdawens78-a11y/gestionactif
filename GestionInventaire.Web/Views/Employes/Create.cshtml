@using GestionInventaire.Web.Models.Employes
@model EmployeCreateViewModel

@{
    ViewData["Title"] = "Nouvel employé";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/employes.css" asp-append-version="true" />
}

<div class="employe-form-page">

    <div class="emp-header">
        <div class="emp-header-left">
            <h1 class="emp-heading">
                <i class="bi bi-person-plus"></i>
                Nouvel employé
            </h1>
            <p class="emp-heading-sub">Ajouter un membre au personnel</p>
        </div>
        <a href="/Employes" class="btn-emp-cancel">
            <i class="bi bi-arrow-left"></i>
            Retour
        </a>
    </div>

    <div class="emp-form-card">
        <div class="emp-form-header">
            <div class="emp-form-icon">
                <i class="bi bi-person-vcard"></i>
            </div>
            <div>
                <p class="emp-form-card-title">Informations de l'employé</p>
                <p class="emp-form-card-subtitle">Nom et prénom obligatoires</p>
            </div>
        </div>

        <div class="emp-form-body">
            <div asp-validation-summary="ModelOnly" class="emp-alert erreur" style="margin-bottom:16px"></div>

            <form method="post" id="empForm">
                @Html.AntiForgeryToken()

                <div class="emp-form-grid">

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Prenom">
                            <i class="bi bi-person"></i> Prénom
                        </label>
                        <input asp-for="Prenom" class="emp-input" placeholder="ex. Valdaya" />
                        <span asp-validation-for="Prenom" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Nom">
                            <i class="bi bi-person"></i> Nom
                        </label>
                        <input asp-for="Nom" class="emp-input" placeholder="ex. Princivil" />
                        <span asp-validation-for="Nom" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Email">
                            <i class="bi bi-envelope"></i> E-mail
                            <span class="opt">(optionnel)</span>
                        </label>
                        <input asp-for="Email" class="emp-input" placeholder="ex. v.princivil@technologis.com" />
                        <span asp-validation-for="Email" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group">
                        <label class="emp-form-label" asp-for="Tel">
                            <i class="bi bi-telephone"></i> Téléphone
                            <span class="opt">(optionnel)</span>
                        </label>
                        <input asp-for="Tel" class="emp-input" placeholder="ex. +509 3700 0000" />
                        <span asp-validation-for="Tel" class="emp-field-error"></span>
                    </div>

                    <div class="emp-form-group full-width">
                        <label class="emp-form-label" for="IdService">
                            <i class="bi bi-building"></i> Service / Département
                            <span class="opt">(optionnel)</span>
                        </label>
                        <div style="display: flex; gap: 8px;">
                            <select asp-for="IdService" class="emp-input" style="flex: 1;">
                                <option value="">-- Sélectionner un service --</option>
                                @foreach (var service in Model.Services)
                                {
                                    <option value="@service.IdService">@service.NomService</option>
                                }
                            </select>
                            <button type="button" id="btnAddService" class="btn-emp-submit"
                                    style="margin-top: 0; white-space: nowrap;">
                                <i class="bi bi-plus"></i>
                                Nouveau
                            </button>
                        </div>
                        <span asp-validation-for="IdService" class="emp-field-error"></span>
                    </div>

                </div>
            </form>
        </div>

        <div class="emp-form-footer">
            <button type="submit" form="empForm" class="btn-emp-submit">
                <i class="bi bi-check-circle"></i>
                Créer l'employé
            </button>
            <a href="/Employes" class="btn-emp-cancel">
                <i class="bi bi-x"></i>
                Annuler
            </a>
        </div>
    </div>

</div>

<!-- Modal pour créer un service -->
<div id="serviceModal" class="emp-modal">
    <div class="emp-modal-content">
        <div class="emp-modal-header">
            <h3 class="emp-modal-title">
                <i class="bi bi-building"></i> Nouveau Service
            </h3>
            <button type="button" class="emp-modal-close" id="closeServiceModal">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="emp-modal-body">
            <div class="emp-form-group">
                <label class="emp-form-label" for="newServiceName">
                    Nom du service
                </label>
                <input type="text" id="newServiceName" class="emp-input"
                       placeholder="ex. Direction, Informatique, RH..." />
                <span id="serviceError" class="emp-field-error"></span>
            </div>
        </div>
        <div class="emp-modal-footer">
            <button type="button" class="btn-emp-submit" id="btnSaveService">
                <i class="bi bi-check-circle"></i>
                Créer
            </button>
            <button type="button" class="btn-emp-cancel" id="btnCancelService">
                <i class="bi bi-x"></i>
                Annuler
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnAddService = document.getElementById('btnAddService');
            const serviceModal = document.getElementById('serviceModal');
            const closeServiceModal = document.getElementById('closeServiceModal');
            const btnSaveService = document.getElementById('btnSaveService');
            const btnCancelService = document.getElementById('btnCancelService');
            const newServiceName = document.getElementById('newServiceName');
            const serviceError = document.getElementById('serviceError');
            const serviceSelect = document.querySelector('select[name="IdService"]');

            function openModal() {
                serviceModal.classList.add('open');
                newServiceName.focus();
            }

            function closeModal() {
                serviceModal.classList.remove('open');
                newServiceName.value = '';
                serviceError.textContent = '';
            }

            btnAddService.addEventListener('click', function (e) {
                e.preventDefault();
                openModal();
            });

            closeServiceModal.addEventListener('click', closeModal);
            btnCancelService.addEventListener('click', closeModal);

            serviceModal.addEventListener('click', function (e) {
                if (e.target === serviceModal) {
                    closeModal();
                }
            });

            btnSaveService.addEventListener('click', async function () {
                const nomService = newServiceName.value.trim();
                if (!nomService) {
                    serviceError.textContent = 'Le nom du service est obligatoire.';
                    return;
                }

                btnSaveService.disabled = true;
                serviceError.textContent = '';

                try {
                    const response = await fetch('/Employes/CreateServiceAjax', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({ nomService: nomService })
                    });

                    if (!response.ok) {
                        const error = await response.json();
                        serviceError.textContent = error.message || 'Erreur lors de la création du service.';
                        return;
                    }

                    const data = await response.json();

                    const option = document.createElement('option');
                    option.value = data.idService;
                    option.textContent = data.nomService;
                    option.selected = true;
                    serviceSelect.appendChild(option);

                    closeModal();
                } catch (error) {
                    console.error('Erreur:', error);
                    serviceError.textContent = 'Une erreur inattendue est survenue.';
                } finally {
                    btnSaveService.disabled = false;
                }
            });

            newServiceName.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    btnSaveService.click();
                }
            });
        });
    </script>
}
