@using GestionInventaire.Web.Models.Home
@model HomeViewModel

@{
    ViewData["Title"] = "Accueil";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-page">

    @* ══ HERO ══ *@
    <div class="home-hero">
        <div class="hero-inner">

            <div class="hero-left">
                <div class="hero-eyebrow">
                    <i class="bi bi-stars"></i>
                    TechnoLogis S.A. — Gestion d'actifs informatiques
                </div>
                <h1 class="hero-title">
                    Bienvenue, <span class="hl">@Model.NomUtilisateur</span>
                </h1>
                <p class="hero-desc">
                    Votre plateforme centralisée pour gérer les actifs informatiques,
                    les stocks, les affectations et les maintenances de TechnoLogis S.A.
                    Tout est à portée de main.
                </p>
                <div class="hero-actions">
                    <a href="/Dashboard" class="btn-hero-primary">
                        <i class="bi bi-speedometer2"></i>
                        Voir le Dashboard
                    </a>
                    <a href="/Actifs" class="btn-hero-secondary">
                        <i class="bi bi-box"></i>
                        Gérer les actifs
                    </a>
                </div>
            </div>

            <div class="hero-right">
                <div class="hero-stat-row">
                    <div class="hero-stat">
                        <span class="hero-stat-val">@Model.TotalActifs</span>
                        <span class="hero-stat-label">Actifs</span>
                    </div>
                    <div class="hero-stat">
                        <span class="hero-stat-val accent">@Model.ActifsDisponibles</span>
                        <span class="hero-stat-label">Disponibles</span>
                    </div>
                </div>
                <div class="hero-stat-row">
                    <div class="hero-stat">
                        <span class="hero-stat-val blue">@Model.ActifsAffectes</span>
                        <span class="hero-stat-label">Affectés</span>
                    </div>
                    <div class="hero-stat">
                        <span class="hero-stat-val amber">@Model.ActifsEnMaintenance</span>
                        <span class="hero-stat-label">Maintenance</span>
                    </div>
                </div>
                <div class="hero-stat-row">
                    <div class="hero-stat">
                        <span class="hero-stat-val red">@Model.StockCritique</span>
                        <span class="hero-stat-label">Stocks crit.</span>
                    </div>
                    <div class="hero-stat">
                        <span class="hero-stat-val">@Model.TotalEmployes</span>
                        <span class="hero-stat-label">Employés</span>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @* ══ MODULES ══ *@
    <div class="home-section">
        <p class="home-section-title">Modules disponibles</p>
        <div class="modules-grid">

            <a href="/Dashboard" class="module-card teal">
                <div class="module-icon">
                    <i class="bi bi-speedometer2"></i>
                </div>
                <div>
                    <p class="module-name">Dashboard</p>
                    <p class="module-desc">Vue globale en temps réel de tous les indicateurs clés</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Actifs" class="module-card blue">
                <div class="module-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <p class="module-name">Actifs</p>
                    <p class="module-desc">Inventaire complet des équipements informatiques</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Stock" class="module-card amber">
                <div class="module-icon">
                    <i class="bi bi-archive"></i>
                </div>
                <div>
                    <p class="module-name">Stock</p>
                    <p class="module-desc">Suivi des niveaux de stock et alertes de réapprovisionnement</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Employes" class="module-card info">
                <div class="module-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <p class="module-name">Employés</p>
                    <p class="module-desc">Gestion du personnel et des affectations d'actifs</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Maintenance" class="module-card red">
                <div class="module-icon">
                    <i class="bi bi-wrench-adjustable"></i>
                </div>
                <div>
                    <p class="module-name">Maintenance</p>
                    <p class="module-desc">Planification et suivi des interventions techniques</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Rapports" class="module-card purple">
                <div class="module-icon">
                    <i class="bi bi-file-earmark-bar-graph"></i>
                </div>
                <div>
                    <p class="module-name">Rapports</p>
                    <p class="module-desc">Génération de rapports et exports de données</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Audit" class="module-card green">
                <div class="module-icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <p class="module-name">Audit</p>
                    <p class="module-desc">Journal des actions et traçabilité complète</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

            <a href="/Parametres" class="module-card pink">
                <div class="module-icon">
                    <i class="bi bi-sliders"></i>
                </div>
                <div>
                    <p class="module-name">Paramètres</p>
                    <p class="module-desc">Configuration du système et des utilisateurs</p>
                </div>
                <i class="bi bi-arrow-right module-arrow"></i>
            </a>

        </div>
    </div>

    @* ══ BAS DE PAGE : ACTIVITÉ + INFOS ══ *@
    <div class="home-bottom">

        @* Activités récentes ─ colonne gauche *@
        <div class="home-bottom-left">
            <p class="home-section-title" style="margin-bottom:0">
                Activités récentes
            </p>

            <div class="activity-timeline">
                @if (Model.DernieresActivites != null && Model.DernieresActivites.Any())
                {
                    @foreach (var item in Model.DernieresActivites)
                    {
                        <div class="tl-item">
                            <div class="tl-dot @item.TypeDot">
                                <i class="@item.IconeAction"></i>
                            </div>
                            <div class="tl-content">
                                <p class="tl-action">@item.Action</p>
                                <div class="tl-meta">
                                    <i class="bi bi-person" style="font-size:11px"></i>
                                    <span>@(string.IsNullOrEmpty(item.UtilisateurNom) ? "Système" : item.UtilisateurNom)</span>
                                    <span>·</span>
                                    <span>@item.RelativeTime</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="tl-empty">
                        <i class="bi bi-inbox"></i>
                        <span>Aucune activité enregistrée</span>
                    </div>
                }
            </div>
        </div>

        @* Infos + liens rapides ─ colonne droite *@
        <div class="home-bottom-right">

            @* Liens rapides *@
            <div class="info-card">
                <div class="info-card-header">
                    <i class="bi bi-lightning-charge"></i>
                    <span>Actions rapides</span>
                </div>
                <div class="info-card-body">
                    <div class="quick-links">
                        <a href="/Actifs/Create" class="quick-link">
                            <i class="bi bi-plus-circle" style="color:var(--accent)"></i>
                            Ajouter un actif
                            <i class="bi bi-arrow-right ql-arrow"></i>
                        </a>
                        <a href="/Employes/Create" class="quick-link">
                            <i class="bi bi-person-plus" style="color:var(--accent2)"></i>
                            Créer un employé
                            <i class="bi bi-arrow-right ql-arrow"></i>
                        </a>
                        <a href="/Maintenance/Create" class="quick-link">
                            <i class="bi bi-wrench" style="color:var(--warn)"></i>
                            Planifier une maintenance
                            <i class="bi bi-arrow-right ql-arrow"></i>
                        </a>
                        <a href="/Affectations/Create" class="quick-link">
                            <i class="bi bi-person-check" style="color:var(--info)"></i>
                            Créer une affectation
                            <i class="bi bi-arrow-right ql-arrow"></i>
                        </a>
                        <a href="/Rapports" class="quick-link">
                            <i class="bi bi-download" style="color:#8b5cf6"></i>
                            Exporter un rapport
                            <i class="bi bi-arrow-right ql-arrow"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Informations système *@
            <div class="info-card">
                <div class="info-card-header">
                    <i class="bi bi-info-circle"></i>
                    <span>Informations système</span>
                </div>
                <div class="info-card-body">
                    <div class="version-info">
                        <div class="version-row">
                            <span class="vr-label">Version</span>
                            <span class="vr-val">v@Model.Version</span>
                        </div>
                        <div class="version-row">
                            <span class="vr-label">Statut</span>
                            <span class="vr-badge stable">Stable</span>
                        </div>
                        <div class="version-row">
                            <span class="vr-label">Rôle</span>
                            <span class="vr-val">@Model.RoleUtilisateur</span>
                        </div>
                        <div class="version-row">
                            <span class="vr-label">Connexion</span>
                            <span class="vr-val">@Model.DateConnexion.ToString("HH:mm")</span>
                        </div>
                        <div class="version-row">
                            <span class="vr-label">Mise à jour</span>
                            <span class="vr-val">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>
