<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechnoLogis</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" />

    <!-- Layout styles -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestionInventaire.Web.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ═══════════════ TOP NAVIGATION ═══════════════ -->
    <nav class="app-topnav">

        <!-- BRAND -->
        <a class="nav-brand" href="/">
            <div class="nav-logo-box">
                <svg viewBox="0 0 24 24">
                    <path d="M3 7l9-4 9 4v10l-9 4-9-4V7z" />
                    <path d="M12 3v18M3 7l9 4 9-4" />
                </svg>
            </div>
            <span class="nav-brand-name">
                Techno<span class="brand-dot">Logis</span>
            </span>
        </a>

        <!-- NAV LINKS -->
        @{
            var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";

            // Contrôleurs visibles dans le menu "Plus"
            var moreControllers = new[]
            {
                "Rapports", "Audit", "Utilisateurs", "Settings"
            };
            var isInMore = moreControllers.Contains(ctrl);
        }

        <div class="nav-links">

            <a href="/" class="nav-link @(ctrl is "Home" or "" ? "active" : "")">
                <i class="bi bi-house"></i>
                <span>Accueil</span>
            </a>

            <a href="/Dashboard" class="nav-link @(ctrl == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>

            <a href="/Actifs" class="nav-link @(ctrl == "Actifs" ? "active" : "")">
                <i class="bi bi-box"></i>
                <span>Actifs</span>
            </a>

            <a href="/Produits" class="nav-link @(ctrl == "Produits" ? "active" : "")">
                <i class="bi bi-box-seam"></i>
                <span>Produits</span>
            </a>

            <a href="/Stocks" class="nav-link @(ctrl == "Stocks" ? "active" : "")">
                <i class="bi bi-archive"></i>
                <span>Stock</span>
            </a>

            <a href="/Employes" class="nav-link @(ctrl == "Employes" ? "active" : "")">
                <i class="bi bi-people"></i>
                <span>Employés</span>
            </a>

            <a href="/Affectations" class="nav-link @(ctrl == "Affectations" ? "active" : "")">
                <i class="bi bi-person-check"></i>
                <span>Affectations</span>
            </a>

            <a href="/Maintenances" class="nav-link @(ctrl == "Maintenances" ? "active" : "")">
                <i class="bi bi-wrench-adjustable"></i>
                <span>Maintenance</span>
            </a>

            @* ── Bouton "Plus" avec dropdown ── *@
            <div class="nav-more">
                <button class="btn-nav-more @(isInMore ? "has-active" : "")" id="navMoreBtn" type="button">
                    <i class="bi bi-grid"></i>
                    Plus
                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="nav-more-dropdown" id="navMoreDropdown">

                    <a href="/Rapports" class="@(ctrl == "Rapports" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph"></i>
                        Rapports
                    </a>

                    <a href="/Audit" class="@(ctrl == "Audit" ? "active" : "")">
                        <i class="bi bi-shield-check"></i>
                        Audit
                    </a>

                    <hr />

                    @* Utilisateurs — lien vers Index, création dans la vue *@
                    <a href="/Utilisateurs" class="@(ctrl is "Utilisateurs" or "Users" ? "active" : "")">
                        <i class="bi bi-person-gear"></i>
                        Utilisateurs
                    </a>

                    <a asp-controller="Settings" asp-action="Index" class="@(ctrl == "Settings" ? "active" : "")">
                        <i class="bi bi-sliders"></i>
                        Paramètres
                    </a>

                </div>
            </div>

        </div>

        <!-- RIGHT ZONE -->
        <div class="nav-right">

            <!-- SEARCH -->
            <div class="nav-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher… (/)" />
            </div>

            <!-- NOTIFICATIONS -->
            <div class="btn-icon" title="Notifications">
                <i class="bi bi-bell"></i>
                <span class="nav-badge">3</span>
            </div>

            <!-- USER MENU -->
            <div class="nav-user">
                <button class="btn-user" id="userMenuBtn">
                    <div class="user-avatar">
                        <img src="https://ui-avatars.com/api/?name=Admin+User&background=00d4aa&color=0b0f1a&bold=true"
                             alt="Admin User" />
                    </div>
                    <span class="user-name">Admin User</span>
                    <i class="bi bi-chevron-down" style="font-size:10px;color:var(--muted)"></i>
                </button>

                <div class="nav-dropdown" id="userDropdown">
                    <a href="/Identity/Account/Manage/Index">
                        <i class="bi bi-person"></i> Profil
                    </a>
                    <a asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-sliders"></i> Paramètres
                    </a>
                    <hr />
                    <a href="/Identity/Account/Logout">
                        <i class="bi bi-box-arrow-right"></i> Déconnexion
                    </a>
                </div>
            </div>

        </div>
    </nav>

    <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
    <div class="app-body">
        <main class="app-main">

            @{
                var fullWidthControllers = new[]
                {
                    "Dashboard", "Home", "Affectations"
                };
                var isFullWidth = fullWidthControllers.Contains(ctrl);
            }

            @if (ctrl == "Dashboard")
            {
                <div class="page-breadcrumb">
                    <i class="bi bi-house" style="font-size:11px"></i>
                    <span class="bc-sep">›</span>
                    <span>Dashboard</span>
                    <span class="bc-sep">·</span>
                    <span class="bc-time">
                        Dernière mise à jour : @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>
                @RenderBody()
            }
            else if (isFullWidth)
            {
                @RenderBody()
            }
            else
            {
                <div class="container-lg">
                    @RenderBody()
                </div>
            }

        </main>
    </div>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="app-footer">
        <p>© 2026 TechnoLogis S.A. — Gestion d'inventaire d'actifs informatiques</p>
        <div class="footer-links">
            <a href="#">Aide</a>
            <a href="#">Confidentialité</a>
            <a href="#">Conditions</a>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Dropdown "Plus" ──
        const moreBtn = document.getElementById('navMoreBtn');
        const moreDropdown = document.getElementById('navMoreDropdown');

        moreBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = moreDropdown.classList.contains('open');

        // Fermer tous les dropdowns ouverts
        document.querySelectorAll('.nav-more-dropdown.open')
        .forEach(d => d.classList.remove('open'));
        document.querySelectorAll('.btn-nav-more.open')
        .forEach(b => b.classList.remove('open'));

        if (!isOpen) {
        // Positionner le dropdown sous le bouton
        const rect = moreBtn.getBoundingClientRect();
        moreDropdown.style.left = (rect.right - 210) + 'px';
        moreDropdown.classList.add('open');
        moreBtn.classList.add('open');
        }
        });

        // Fermer en cliquant ailleurs
        document.addEventListener('click', () => {
        moreDropdown?.classList.remove('open');
        moreBtn?.classList.remove('open');
        });

        // Empêcher la fermeture en cliquant dans le dropdown
        moreDropdown?.addEventListener('click', (e) => {
        e.stopPropagation();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
