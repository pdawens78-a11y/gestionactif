@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Mot de passe oublié";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/forgot-password.css"
          asp-append-version="true" />
}

<div class="auth-card forgot-card">

    <!-- Brand -->
    <a class="auth-brand" href="/">
        <div class="auth-logo-box">
            <svg viewBox="0 0 24 24">
                <path d="M3 7l9-4 9 4v10l-9 4-9-4V7z" />
                <path d="M12 3v18M3 7l9 4 9-4" />
            </svg>
        </div>

        <span class="auth-brand-name">
            Techno<span class="brand-dot">Logis</span>
        </span>
    </a>

    <!-- Header -->
    <div class="forgot-header">

        <h1 class="forgot-title">
            Mot de passe oublié
        </h1>

        <p class="forgot-subtitle">
            Entrez votre adresse e-mail afin de recevoir
            un lien sécurisé de réinitialisation.
        </p>

    </div>

    <!-- Validation -->
    <div asp-validation-summary="ModelOnly"
         class="auth-validation">
    </div>

    <!-- Form -->
    <form method="post"
          class="forgot-form">

        <div class="auth-group">

            <label asp-for="Input.Email"
                   class="auth-label">
                Adresse e-mail
            </label>

            <div class="auth-input-wrap">

                <i class="bi bi-envelope"></i>

                <input asp-for="Input.Email"
                       class="auth-input"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="vous@technologis.com" />

            </div>

            <span asp-validation-for="Input.Email"
                  class="auth-error">
            </span>

        </div>

        <button type="submit"
                class="auth-btn forgot-btn">

            <i class="bi bi-arrow-repeat"></i>
            Envoyer le lien

        </button>

    </form>

    <!-- Footer -->
    <div class="forgot-footer">

        <a asp-page="./Login">

            <i class="bi bi-arrow-left"></i>
            Retour à la connexion

        </a>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}